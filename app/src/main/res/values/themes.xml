<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Light variant. The DeviceDefault parent maps to Material 3 on Android
      12+ devices, which is the only world Lobber runs in (min/target SDK 36).
      The splash background uses the system's dynamic Material You neutral
      palette so the pre-Compose window matches whatever wallpaper-derived
      surface the rest of the app renders in.
    -->
    <style name="Theme.Lobber" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowSplashScreenBackground">@android:color/system_neutral1_50</item>
    </style>
</resources>
